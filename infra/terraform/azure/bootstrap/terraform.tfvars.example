# Run-once bootstrap. Copy to terraform.tfvars and override at least
# state_storage_account_name (must be globally unique). See README.md before
# applying.

# subscription_id = "00000000-0000-0000-0000-000000000000"

location          = "eastus"
github_repository = "jasonp2323/keda-gpu-scaler"
app_display_name  = "keda-gpu-scaler-e2e"
environments      = ["e2e-azure"]

# Set to false to reference an existing app registration (by app_display_name)
# instead of creating a new one — use this if state was lost, to avoid
# creating a duplicate app with a new client_id. app_display_name must be
# unique in the tenant for the lookup to resolve to a single app.
# create_app_registration = false

# For repos created after 2026-07-15, GitHub's OIDC `sub` embeds numeric IDs
# (repo:OWNER@OWNER_ID/REPO@REPO_ID:...). Set both to also federate that
# immutable form; leave unset for classic-only. Fetch with:
#   gh api repos/jasonp2323/keda-gpu-scaler --jq '{owner_id: .owner.id, repo_id: .id}'
# github_owner_id = "0000000"
# github_repo_id  = "000000000"

state_resource_group_name  = "keda-gpu-scaler-tfstate-rg"
state_storage_account_name = "kedagpuscalertfstate" # CHANGE ME: must be globally unique
state_container_name       = "tfstate"
